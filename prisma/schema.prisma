generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(cuid())
  name         String
  passwordHash String
  role         Role     @default(CHILD)
  createdAt    DateTime @default(now())

  progress    UserProgress[]
  testResults TestResult[]

  @@map("users")
}

enum Role {
  ADMIN
  CHILD
}

model LearningLevel {
  id          String       @id @default(cuid())
  name        String
  nameKz      String
  emoji       String       @default("🎯")
  number      Int          @default(1)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())

  sections    Section[]
  testResults TestResult[]

  @@unique([number])
  @@map("learning_levels")
}

model Section {
  id        String   @id @default(cuid())
  levelId   String?
  name      String
  nameKz    String
  emoji     String   @default("📁")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  level     LearningLevel? @relation(fields: [levelId], references: [id], onDelete: Cascade)
  cards     Card[]

  @@index([levelId])
  @@map("sections")
}

model Card {
  id        String   @id @default(cuid())
  sectionId String
  ru        String
  kz        String
  emoji     String   @default("🃏")
  imageUrl  String?
  gifUrl    String?
  audioRuUrl String?
  audioKzUrl String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  section  Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress UserProgress[]

  @@index([sectionId])
  @@map("cards")
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  learnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@map("user_progress")
}

model TestResult {
  id            String   @id @default(cuid())
  userId        String
  levelId       String?
  lessonIndex   Int?
  correctCount  Int
  totalCount    Int
  completedAt   DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  level LearningLevel? @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([levelId])
  @@map("test_results")
}
