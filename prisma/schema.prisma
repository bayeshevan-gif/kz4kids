generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(cuid())
  name         String
  passwordHash String
  role         Role     @default(CHILD)
  createdAt    DateTime @default(now())

  progress    UserProgress[]
  testResults TestResult[]

  @@map("users")
}

enum Role {
  ADMIN
  CHILD
}

model LearningLevel {
  id          String   @id @default(cuid())
  title       String   @default("Новый уровень")
  description String?
  emoji       String   @default("🎯")
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  levelSections LevelSection[]
  testResults   TestResult[]

  @@map("learning_levels")
}

model Section {
  id        String   @id @default(cuid())
  name      String
  nameKz    String
  emoji     String   @default("📁")
  order     Int      @default(0)
  createdAt DateTime @default(now())

  levelSections LevelSection[]
  cards         Card[]

  @@map("sections")
}

model LevelSection {
  levelId   String
  sectionId String
  order     Int      @default(0)

  level   LearningLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  section Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([levelId, sectionId])
  @@index([sectionId])
  @@map("level_sections")
}

model Card {
  id             String   @id @default(cuid())
  sectionId      String
  ru             String
  kz             String
  emoji          String   @default("🃏")
  imageUrl       String?
  gifUrl         String?
  audioRuUrl     String?
  audioKzUrl     String?
  audioUrl       String?
  audioFileName  String?
  audioDuration  Int?
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  section  Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress UserProgress[]

  @@index([sectionId])
  @@map("cards")
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  learnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@map("user_progress")
}

model TestResult {
  id            String   @id @default(cuid())
  userId        String
  levelId       String?
  lessonIndex   Int?
  correctCount  Int
  totalCount    Int
  completedAt   DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  level LearningLevel? @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([levelId])
  @@map("test_results")
}
