# База данных локально: SQLite. Для быстрого запуска достаточно этих настроек.
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Для Vercel / Postgres используйте PostgreSQL:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://username:password@localhost:5432/uiren?schema=public"

# Секретный ключ для JWT-сессий (любая длинная случайная строка)
SESSION_SECRET="your-super-secret-key-at-least-32-characters-long"

# Настройки для первоначального заселения базы данных (seed)
SEED_ADMIN_PASSWORD="admin123"
SEED_SECRET="let-me-in-2026"

# Токен Vercel Blob для загрузки картинок/анимаций карточек (необязательно для локального запуска без картинок)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
